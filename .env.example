# Frontend (build-time)
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_auth0_spa_client_id
VITE_AUTH0_AUDIENCE=https://twitter-like-api
# Leave empty to use nginx reverse-proxy (/api -> backend)
VITE_API_BASE_URL=

# Backend (runtime)
AUTH0_ISSUER_URI=https://your-tenant.us.auth0.com/
AUTH0_AUDIENCE=https://twitter-like-api
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Ports
FRONTEND_PORT=5173
BACKEND_PORT=8080

# Optional PostgreSQL profile (only used with --profile postgres)
POSTGRES_DB=twitterdb
POSTGRES_USER=twitter
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Uncomment only if you want backend to use Postgres instead of H2:
# SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/twitterdb
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
# SPRING_DATASOURCE_USERNAME=twitter
# SPRING_DATASOURCE_PASSWORD=change_me
# SPRING_JPA_HIBERNATE_DDL_AUTO=update
