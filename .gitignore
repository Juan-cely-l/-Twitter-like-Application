# =========================
# Global ignores (monorepo)
# =========================

# OS files
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100/
.Trashes/

# IDEs / editors
**/.idea/
*.iml
**/.vscode/*
!**/.vscode/extensions.json
*.swp
*.swo
*~
.classpath
.project
.settings/

# Logs
logs/
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Coverage / reports
coverage/
**/coverage/
.nyc_output/

# Caches / temporary files
tmp/
temp/
*.tmp
*.temp
.cache/
**/.cache/

# Local environment and secrets
.env
.env.local
.env.*.local
*.env
*.pem
*.key
*.p12
*.jks

# Keep sample envs versioned
!.env.example
